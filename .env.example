# Environment Variables Template

# Copy this file to .env and fill in your actual values
# DO NOT commit .env file with real API keys to GitHub

# ==========================================
# FRONTEND (.env in root directory)
# ==========================================

# OpenWeatherMap API Key
# Get yours at: https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here


# ==========================================
# BACKEND (backend/.env)
# ==========================================

# OpenWeatherMap API Key (same as frontend)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Flask Environment
# Options: development, production
FLASK_ENV=development

# Flask Debug Mode
# Set to 1 for development, 0 for production
FLASK_DEBUG=1

# Database Configuration
# Default: SQLite (weather.db)
DATABASE_URL=sqlite:///weather.db

# API Rate Limit (requests per minute)
RATE_LIMIT=60

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# CORS Settings
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Server Port (default: 5000)
FLASK_PORT=5000


# ==========================================
# Optional: Advanced Configuration
# ==========================================

# Cache expiration (seconds)
CACHE_EXPIRATION=3600

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Enable test mode (for testing without real API calls)
TEST_MODE=False

# Mail configuration (if needed for notifications)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# JWT Secret (for user authentication)
JWT_SECRET_KEY=your_secret_key_change_this_in_production

# Database backup path
BACKUP_PATH=./backups


# ===========================
# Notes
# ===========================

# 1. Never commit actual .env files with real keys
# 2. Add .env to .gitignore
# 3. Share this .env.example with team for reference
# 4. Rotate API keys regularly
# 5. Use different keys for development/production
# 6. Keep passwords secure and never share them
